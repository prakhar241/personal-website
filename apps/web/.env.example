# ============================================
# Environment Variables for Local Development
# Copy this to .env.local and fill in values
# ============================================

# Database
DATABASE_URL="postgresql://bloguser:blogpass@localhost:5432/blogdb?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="<generate-with: openssl rand -base64 32>"

# Azure AD / Entra ID (Admin Login)
AZURE_AD_CLIENT_ID="<YOUR_AZURE_AD_APP_CLIENT_ID>"
AZURE_AD_CLIENT_SECRET="<YOUR_AZURE_AD_APP_CLIENT_SECRET>"
AZURE_AD_TENANT_ID="<YOUR_AZURE_AD_TENANT_ID>"

# Admin email - only this email can access admin routes
ADMIN_EMAIL="<YOUR_EMAIL@example.com>"

# Azure Blob Storage (for image uploads)
AZURE_STORAGE_ACCOUNT_NAME="<YOUR_STORAGE_ACCOUNT>"
AZURE_STORAGE_ACCOUNT_KEY="<YOUR_STORAGE_KEY>"
AZURE_STORAGE_CONTAINER_NAME="blog-images"

# Azure Application Insights
NEXT_PUBLIC_APPINSIGHTS_CONNECTION_STRING="<YOUR_APPINSIGHTS_CONNECTION_STRING>"

# Azure Event Hubs (Kafka-compatible telemetry streaming)
# Leave empty for local dev - events will be logged to console
EVENTHUB_CONNECTION_STRING=""
EVENTHUB_NAME="telemetry-events"

# OpenTelemetry
OTEL_SERVICE_NAME="personal-website"
OTEL_EXPORTER_OTLP_ENDPOINT="http://localhost:4318"

# Site Config
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="My Blog"

# Azure Communication Services (Email notifications)
# Leave empty for local dev - subscribe flow works but emails won't send
ACS_CONNECTION_STRING=""
ACS_SENDER_ADDRESS=""
